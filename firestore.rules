rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn()
        && currentUser().data.isActive == true
        && currentUser().data.role == role;
    }

    function isAdmin() {
      return hasRole('SUPER_ADMIN');
    }

    function isOperator() {
      return hasRole('OPERATOR');
    }

    function isDriver() {
      return hasRole('DRIVER');
    }

    function isBackOffice() {
      return isAdmin() || isOperator();
    }

    function isCompleteCustomer() {
      return hasRole('CUSTOMER')
        && currentUser().data.name is string
        && currentUser().data.phoneNumber is string
        && currentUser().data.addressText is string
        && currentUser().data.location is map
        && currentUser().data.locationValidationStatus
          == 'INSIDE_SERVICE_AREA';
    }

    function validCustomerProfile() {
      return request.resource.data.keys().hasOnly([
          'name',
          'email',
          'phoneNumber',
          'role',
          'isActive',
          'addressText',
          'district',
          'villageId',
          'location',
          'locationAccuracyMeters',
          'locationSource',
          'locationValidationStatus',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'name',
          'email',
          'phoneNumber',
          'role',
          'isActive',
          'addressText',
          'district',
          'villageId',
          'location',
          'locationSource',
          'locationValidationStatus',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.phoneNumber is string
        && request.resource.data.phoneNumber.matches('^628[0-9]{7,12}$')
        && request.resource.data.role == 'CUSTOMER'
        && request.resource.data.isActive == true
        && request.resource.data.addressText is string
        && request.resource.data.addressText.size() >= 8
        && request.resource.data.addressText.size() <= 500
        && request.resource.data.district in [
          'WATANG_SAWITTO',
          'PALETEANG'
        ]
        && request.resource.data.villageId is string
        && request.resource.data.villageId.size() > 0
        && request.resource.data.location is map
        && request.resource.data.location.keys().hasOnly(['lat', 'lng'])
        && request.resource.data.location.lat is number
        && request.resource.data.location.lng is number
        && request.resource.data.locationSource in [
          'BROWSER_GPS',
          'MANUAL_PIN'
        ]
        && request.resource.data.locationValidationStatus
          == 'INSIDE_SERVICE_AREA'
        && request.resource.data.updatedAt == request.time;
    }

    function isAssignedDriver() {
      return isDriver() && resource.data.assignedDriverId == request.auth.uid;
    }

    function driverOwnsPickup(pickupRequestId) {
      return get(
        /databases/$(database)/documents/pickupRequests/$(pickupRequestId)
      ).data.assignedDriverId == request.auth.uid;
    }

    function validStatusTransition(from, to) {
      return
        (from == 'NEW' && to in [
          'NEEDS_INFO',
          'NEEDS_OPERATOR_REVIEW',
          'CONFIRMED',
          'REJECTED',
          'CANCELLED'
        ])
        || (from == 'NEEDS_INFO' && to in [
          'NEEDS_OPERATOR_REVIEW',
          'CONFIRMED',
          'REJECTED',
          'CANCELLED'
        ])
        || (from == 'NEEDS_OPERATOR_REVIEW' && to in [
          'NEEDS_INFO',
          'CONFIRMED',
          'REJECTED',
          'CANCELLED'
        ])
        || (from == 'CONFIRMED' && to in [
          'SCHEDULED',
          'REJECTED',
          'CANCELLED'
        ])
        || (from == 'SCHEDULED' && to in ['ASSIGNED', 'CANCELLED'])
        || (from == 'ASSIGNED' && to in [
          'IN_PROGRESS',
          'NEEDS_OPERATOR_REVIEW',
          'SCHEDULED',
          'CANCELLED'
        ])
        || (from == 'IN_PROGRESS' && to in [
          'ASSIGNED',
          'NEEDS_OPERATOR_REVIEW',
          'COMPLETED',
          'EXTRA_TRIP_REQUIRED',
          'CANCELLED'
        ])
        || (from == 'EXTRA_TRIP_REQUIRED' && to in [
          'SCHEDULED',
          'ASSIGNED',
          'COMPLETED',
          'CANCELLED'
        ]);
    }

    function pickupAuditAfter() {
      return getAfter(
        /databases/$(database)/documents/auditLogs/$(request.resource.data.lastAuditId)
      );
    }

    function validPickupAudit(ticketId, action) {
      let audit = pickupAuditAfter().data;
      return request.resource.data.lastAuditId is string
        && existsAfter(
          /databases/$(database)/documents/auditLogs/$(request.resource.data.lastAuditId)
        )
        && audit.actorId == request.auth.uid
        && audit.actorRole == currentUser().data.role
        && audit.action == action
        && audit.entityType == 'PICKUP_REQUEST'
        && audit.entityId == ticketId
        && audit.before.status == resource.data.status
        && audit.after.status == request.resource.data.status
        && audit.createdAt == request.time;
    }

    function operatorAuditMatches(ticketId) {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return (
          changed.hasAny(['scheduledDate', 'scheduledTimeWindow'])
          && validPickupAudit(ticketId, 'PICKUP_SCHEDULED')
        )
        || (
          changed.hasAny(['assignedDriverId', 'assignedDriverName'])
          && validPickupAudit(ticketId, 'PICKUP_DRIVER_ASSIGNED')
        )
        || (
          !changed.hasAny([
            'scheduledDate',
            'scheduledTimeWindow',
            'assignedDriverId',
            'assignedDriverName'
          ])
          && validPickupAudit(ticketId, 'PICKUP_STATUS_CHANGED')
        );
    }

    function operatorUpdatesOperationalFields(ticketId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'status',
        'scheduledDate',
        'scheduledTimeWindow',
        'assignedDriverId',
        'assignedDriverName',
        'operatorNotes',
        'rejectedReason',
        'updatedAt',
        'lastAuditId'
      ])
      && validStatusTransition(resource.data.status, request.resource.data.status)
      && request.resource.data.updatedAt == request.time
      && operatorAuditMatches(ticketId);
    }

    function operatorUpdatesImpactFields(ticketId) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'serviceCategory',
        'serviceModel',
        'wasteTypes',
        'estimatedWeightKg',
        'finalWeightKg',
        'dataQuality',
        'partnerDestination',
        'serviceFee',
        'operationalCost',
        'paidAmount',
        'paymentStatus',
        'impactTags',
        'updatedAt',
        'lastAuditId'
      ])
      && request.resource.data.status == resource.data.status
      && request.resource.data.updatedAt == request.time
      && validPickupAudit(ticketId, 'PICKUP_IMPACT_UPDATED');
    }

    function driverStartsPickup(ticketId) {
      return resource.data.status == 'ASSIGNED'
        && request.resource.data.status == 'IN_PROGRESS'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'startedAt',
          'updatedAt',
          'lastAuditId'
        ])
        && request.resource.data.startedAt == request.time
        && request.resource.data.updatedAt == request.time
        && validPickupAudit(ticketId, 'PICKUP_STARTED');
    }

    function driverCompletesPickup(ticketId) {
      return resource.data.status in ['ASSIGNED', 'IN_PROGRESS']
        && request.resource.data.status in [
          'ASSIGNED',
          'NEEDS_OPERATOR_REVIEW',
          'COMPLETED',
          'EXTRA_TRIP_REQUIRED',
          'CANCELLED'
        ]
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'driverNotes',
          'finalWeightKg',
          'dataQuality',
          'partnerDestination',
          'completedAt',
          'cancelledAt',
          'updatedAt',
          'lastAuditId'
        ])
        && request.resource.data.updatedAt == request.time
        && existsAfter(
          /databases/$(database)/documents/pickupProofs/$(ticketId)
        )
        && getAfter(
          /databases/$(database)/documents/pickupProofs/$(ticketId)
        ).data.driverId == request.auth.uid
        && validPickupAudit(ticketId, 'PICKUP_RESULT_RECORDED');
    }

    match /users/{userId} {
      allow read: if (signedIn() && request.auth.uid == userId)
        || isBackOffice();
      allow create: if (
          signedIn()
          && request.auth.uid == userId
          && validCustomerProfile()
          && request.resource.data.createdAt == request.time
        )
        || (
          isAdmin()
          && request.resource.data.keys().hasOnly([
            'name',
            'email',
            'phoneNumber',
            'role',
            'isActive'
          ])
          && request.resource.data.name is string
          && request.resource.data.email is string
          && request.resource.data.role in [
            'SUPER_ADMIN',
            'OPERATOR',
            'DRIVER',
            'CUSTOMER'
          ]
          && request.resource.data.isActive is bool
        );
      allow update: if (
          signedIn()
          && request.auth.uid == userId
          && resource.data.role == 'CUSTOMER'
          && request.resource.data.role == resource.data.role
          && request.resource.data.isActive == resource.data.isActive
          && request.resource.data.email == resource.data.email
          && request.resource.data.createdAt == resource.data.createdAt
          && validCustomerProfile()
        )
        || (isAdmin()
        && request.resource.data.keys().hasOnly([
          'name',
          'email',
          'phoneNumber',
          'role',
          'isActive'
        ])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.role in [
          'SUPER_ADMIN',
          'OPERATOR',
          'DRIVER',
          'CUSTOMER'
        ]
        && request.resource.data.isActive is bool);
      allow delete: if false;
    }

    match /customers/{customerId} {
      allow read, create, update: if isBackOffice();
      allow delete: if false;
    }

    match /pickupRequests/{ticketId} {
      allow read: if isBackOffice()
        || isAssignedDriver()
        || (
          signedIn()
          && resource.data.ownerUid == request.auth.uid
        );
      allow create: if isBackOffice()
        || (
          isCompleteCustomer()
          && request.resource.data.keys().hasOnly([
            'ticketCode',
            'source',
            'customerId',
            'ownerUid',
            'customerPhoneNumber',
            'customerName',
            'district',
            'villageId',
            'addressText',
            'location',
            'locationAccuracyMeters',
            'locationSource',
            'locationValidationStatus',
            'serviceType',
            'serviceCategory',
            'serviceModel',
            'volumeLevel',
            'tricycleLoadEstimate',
            'wasteDescription',
            'wasteTypes',
            'dataQuality',
            'paymentStatus',
            'impactTags',
            'photoUrls',
            'intakePhotoMediaIds',
            'status',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.keys().hasAll([
            'ticketCode',
            'source',
            'customerId',
            'ownerUid',
            'customerPhoneNumber',
            'customerName',
            'district',
            'villageId',
            'addressText',
            'location',
            'locationSource',
            'locationValidationStatus',
            'serviceType',
            'serviceCategory',
            'serviceModel',
            'volumeLevel',
            'tricycleLoadEstimate',
            'wasteTypes',
            'dataQuality',
            'paymentStatus',
            'impactTags',
            'photoUrls',
            'intakePhotoMediaIds',
            'status',
            'createdAt',
            'updatedAt'
          ])
          && request.resource.data.ticketCode.matches(
            '^JSP-[0-9]{8}-[0-9]{4}$'
          )
          && request.resource.data.source == 'PWA'
          && request.resource.data.customerId == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.customerPhoneNumber
            == currentUser().data.phoneNumber
          && request.resource.data.customerName == currentUser().data.name
          && request.resource.data.district in [
            'WATANG_SAWITTO',
            'PALETEANG'
          ]
          && request.resource.data.villageId is string
          && request.resource.data.villageId.size() > 0
          && request.resource.data.addressText is string
          && request.resource.data.addressText.size() >= 8
          && request.resource.data.addressText.size() <= 500
          && request.resource.data.location is map
          && request.resource.data.location.keys().hasOnly(['lat', 'lng'])
          && request.resource.data.locationSource in [
            'BROWSER_GPS',
            'MANUAL_PIN'
          ]
          && request.resource.data.locationValidationStatus
            == 'INSIDE_SERVICE_AREA'
          && request.resource.data.serviceType in [
            'REGULAR_HOUSEHOLD_PICKUP',
            'ONE_TRIP_TRICYCLE'
          ]
          && request.resource.data.serviceCategory == 'warga'
          && request.resource.data.serviceModel == 'gratis'
          && request.resource.data.volumeLevel in [
            'SMALL',
            'MEDIUM',
            'LARGE',
            'OVERSIZED'
          ]
          && request.resource.data.tricycleLoadEstimate in [
            'QUARTER',
            'HALF',
            'FULL',
            'OVER_CAPACITY'
          ]
          && request.resource.data.wasteTypes is list
          && request.resource.data.dataQuality == 'estimated_by_user'
          && request.resource.data.paymentStatus == 'gratis'
          && request.resource.data.impactTags is list
          && request.resource.data.photoUrls is list
          && request.resource.data.photoUrls.size() == 0
          && request.resource.data.intakePhotoMediaIds is list
          && request.resource.data.intakePhotoMediaIds.size() == 1
          && existsAfter(
            /databases/$(database)/documents/customerWasteMedia/$(request.resource.data.intakePhotoMediaIds[0])
          )
          && getAfter(
            /databases/$(database)/documents/customerWasteMedia/$(request.resource.data.intakePhotoMediaIds[0])
          ).data.ownerUid == request.auth.uid
          && request.resource.data.status == 'NEW'
          && request.resource.data.createdAt == request.time
          && request.resource.data.updatedAt == request.time
        );
      allow update: if (
          isBackOffice()
          && (
            operatorUpdatesOperationalFields(ticketId)
            || operatorUpdatesImpactFields(ticketId)
          )
        )
        || (
          isAssignedDriver()
          && request.resource.data.assignedDriverId == request.auth.uid
          && (
            driverStartsPickup(ticketId)
            || driverCompletesPickup(ticketId)
          )
        );
      allow delete: if false;
    }

    match /pickupSchedules/{scheduleId} {
      allow read: if isBackOffice()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create, update: if isBackOffice();
      allow delete: if false;
    }

    match /pickupProofs/{proofId} {
      allow read: if isBackOffice()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create: if isDriver()
        && proofId == request.resource.data.pickupRequestId
        && request.resource.data.driverId == request.auth.uid
        && driverOwnsPickup(request.resource.data.pickupRequestId)
        && request.resource.data.keys().hasOnly([
          'pickupRequestId',
          'driverId',
          'beforePhotoUrls',
          'afterPhotoUrls',
          'actualTripResult',
          'driverNotes',
          'finalWeightKg',
          'partnerDestination',
          'createdAt'
        ])
        && request.resource.data.beforePhotoUrls is list
        && request.resource.data.beforePhotoUrls.size() <= 5
        && request.resource.data.afterPhotoUrls is list
        && request.resource.data.afterPhotoUrls.size() <= 5
        && (
          request.resource.data.beforePhotoUrls.size() > 0
          || request.resource.data.afterPhotoUrls.size() > 0
        )
        && request.resource.data.actualTripResult in [
          'COMPLETED_ONE_TRIP',
          'PARTIAL_PICKUP',
          'EXTRA_TRIP_REQUIRED',
          'CUSTOMER_NOT_AVAILABLE',
          'WASTE_NOT_READY',
          'LOCATION_NOT_FOUND',
          'ACCESS_BLOCKED',
          'HAZARDOUS_WASTE_FOUND',
          'CANCELLED_ON_SITE'
        ]
        && (
          !request.resource.data.keys().hasAny(['finalWeightKg'])
          || request.resource.data.finalWeightKg == null
          || request.resource.data.finalWeightKg is number
        )
        && (
          !request.resource.data.keys().hasAny(['partnerDestination'])
          || request.resource.data.partnerDestination == null
          || request.resource.data.partnerDestination in [
            'bank_sampah_peduli_pinrang',
            'tps3r_paleteang_bersinar',
            'tps3r_lain',
            'pengepul',
            'kompos_maggot',
            'residu'
          ]
        )
        && (
          request.resource.data.actualTripResult == 'COMPLETED_ONE_TRIP'
          || (
            request.resource.data.driverNotes is string
            && request.resource.data.driverNotes.size() > 0
            && request.resource.data.driverNotes.size() <= 1000
          )
        )
        && request.resource.data.createdAt == request.time;
      allow update: if false;
      allow delete: if false;
    }

    match /pickupProofMedia/{mediaId} {
      allow read: if isBackOffice()
        || (isDriver() && resource.data.driverId == request.auth.uid);
      allow create, update: if isDriver()
        && request.resource.data.driverId == request.auth.uid
        && driverOwnsPickup(request.resource.data.pickupRequestId)
        && request.resource.data.keys().hasOnly([
          'pickupRequestId',
          'driverId',
          'kind',
          'contentType',
          'byteSize',
          'width',
          'height',
          'dataUrl',
          'originalName',
          'sequence',
          'createdAt'
        ])
        && request.resource.data.kind in ['before', 'after']
        && request.resource.data.contentType == 'image/jpeg'
        && request.resource.data.byteSize > 0
        && request.resource.data.byteSize <= 300000
        && request.resource.data.dataUrl is string
        && request.resource.data.dataUrl.size() <= 410000;
      allow delete: if false;
    }

    match /customerWasteMedia/{mediaId} {
      allow read: if isBackOffice()
        || (
          signedIn()
          && resource.data.ownerUid == request.auth.uid
        )
        || (
          isDriver()
          && driverOwnsPickup(resource.data.pickupRequestId)
        );
      allow create: if isCompleteCustomer()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'pickupRequestId',
          'ownerUid',
          'contentType',
          'byteSize',
          'width',
          'height',
          'dataUrl',
          'originalName',
          'createdAt'
        ])
        && request.resource.data.pickupRequestId is string
        && existsAfter(
          /databases/$(database)/documents/pickupRequests/$(request.resource.data.pickupRequestId)
        )
        && getAfter(
          /databases/$(database)/documents/pickupRequests/$(request.resource.data.pickupRequestId)
        ).data.ownerUid == request.auth.uid
        && getAfter(
          /databases/$(database)/documents/pickupRequests/$(request.resource.data.pickupRequestId)
        ).data.intakePhotoMediaIds.hasAny([mediaId])
        && request.resource.data.contentType == 'image/jpeg'
        && request.resource.data.byteSize > 0
        && request.resource.data.byteSize <= 300000
        && request.resource.data.width is int
        && request.resource.data.height is int
        && request.resource.data.dataUrl is string
        && request.resource.data.dataUrl.size() <= 410000
        && request.resource.data.originalName is string
        && request.resource.data.originalName.size() <= 120
        && request.resource.data.createdAt == request.time;
      allow update, delete: if false;
    }

    match /whatsappMessages/{messageId} {
      allow read: if isBackOffice();
      allow write: if false;
    }

    match /aiAnalyses/{analysisId} {
      allow read: if isBackOffice();
      allow write: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if (isBackOffice() || isDriver())
        && request.resource.data.keys().hasOnly([
          'actorId',
          'actorRole',
          'action',
          'entityType',
          'entityId',
          'before',
          'after',
          'createdAt'
        ])
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.actorRole == currentUser().data.role
        && request.resource.data.action in [
          'PICKUP_STATUS_CHANGED',
          'PICKUP_IMPACT_UPDATED',
          'PICKUP_SCHEDULED',
          'PICKUP_DRIVER_ASSIGNED',
          'PICKUP_STARTED',
          'PICKUP_RESULT_RECORDED'
        ]
        && request.resource.data.entityType == 'PICKUP_REQUEST'
        && request.resource.data.entityId is string
        && request.resource.data.before is map
        && request.resource.data.after is map
        && request.resource.data.createdAt == request.time
        && getAfter(
          /databases/$(database)/documents/pickupRequests/$(request.resource.data.entityId)
        ).data.lastAuditId == logId;
      allow update, delete: if false;
    }

    match /ticketCounters/{counterId} {
      allow read, write: if false;
    }

    match /idempotencyKeys/{keyId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
