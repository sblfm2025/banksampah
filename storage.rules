rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /customer-waste/{allPaths=**} {
      allow read, write: if false;
    }

    // Produksi memakai pickupProofMedia di Firestore. Storage ditutup agar
    // bukti yang memuat rumah atau warga tidak terbaca semua user login.
    match /pickup-proofs/{allPaths=**} {
      allow read, write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
